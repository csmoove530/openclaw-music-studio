# OpenClaw Music Studio Environment Configuration
# SECURITY: Copy this to .env and NEVER commit .env to version control
# chmod 600 ~/.openclaw/.env

# ============================================
# DIRECTORY PATHS
# ============================================
OPENCLAW_CONFIG_DIR=/path/to/.openclaw
OPENCLAW_WORKSPACE_DIR=/path/to/.openclaw/workspace

# ============================================
# GATEWAY CONFIGURATION
# ============================================
# Loopback only - prevents external access
OPENCLAW_GATEWAY_PORT=18790
OPENCLAW_BRIDGE_PORT=18791
OPENCLAW_GATEWAY_BIND=loopback

# Authentication token - generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_WITH_openssl_rand_-hex_32

# ============================================
# API KEYS (keep secret!)
# ============================================
# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ============================================
# MUSIC GENERATION (required for EvoLink skill)
# ============================================
# Get from https://evolink.ai
EVOLINK_API_KEY=YOUR_EVOLINK_KEY_HERE

# ATXP Connection for payment (required for paid generation)
ATXP_CONNECTION=https://accounts.atxp.ai?connection_token=YOUR_TOKEN&account_id=YOUR_ACCOUNT

# ============================================
# TELEGRAM BOT (moved from config JSON for security)
# ============================================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ============================================
# DOCKER IMAGE
# ============================================
OPENCLAW_IMAGE=openclaw:local

# ============================================
# SECURITY: Leave these empty
# ============================================
OPENCLAW_EXTRA_MOUNTS=
OPENCLAW_HOME_VOLUME=
OPENCLAW_DOCKER_APT_PACKAGES=
